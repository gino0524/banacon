# banacon 환경변수 — 이 파일을 .env.local로 복사해 값을 채운다.
# .env.local은 git에 커밋되지 않는다(.gitignore).

# Neon Postgres connection string (서버 전용, 절대 NEXT_PUBLIC_ 아님)
DATABASE_URL=

# 세션 쿠키 서명용 비밀키 (랜덤 32바이트 이상). 예: openssl rand -hex 32
SESSION_SECRET=

# 친구방에 공유할 초대코드 (로그인 1차 관문)
APP_INVITE_CODE=

# 임박 알림 cron route 보호용 비밀값
CRON_SECRET=
